# mcp-infra-lens — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ── Transport ──────────────────────────────────────────────────────────────────
# MCP transport mode: "stdio" (default, for Claude Desktop / VS Code)
#                     "http"  (for network-accessible deployments)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=127.0.0.1   # IMPORTANT: keep on loopback; put a reverse proxy in front

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# Log format: "json" (production) | "pretty" (development)
LOG_FORMAT=json

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database for metric baselines and snapshots.
# Default: ~/.mcp-infra-lens/metrics.db
# MCP_DB_PATH=/custom/path/metrics.db

# ── Analysis ──────────────────────────────────────────────────────────────────
# Number of metric samples collected per analyze_server call (higher = more accurate baseline)
# Default: 3
# MCP_COLLECT_SAMPLES=3

# Z-score threshold above which a metric is flagged as anomalous.
# Default: 2.0  (flag anything more than 2 standard deviations from baseline)
# MCP_ZSCORE_THRESHOLD=2.0

# Minimum number of baseline data points required before z-score is meaningful.
# Default: 5
# MCP_BASELINE_MIN_SAMPLES=5

# ── SSH ───────────────────────────────────────────────────────────────────────
# Default SSH port used when no port is specified in a tool call.
# Default: 22
# MCP_SSH_DEFAULT_PORT=22

# SSH connection timeout in milliseconds.
# Default: 10000 (10 seconds)
# MCP_SSH_TIMEOUT_MS=10000

# Strict host key checking. Set to "true" in production environments.
# WARNING: false is the default for compatibility — restrict network access accordingly.
# Default: false
# MCP_SSH_STRICT_HOST_CHECKING=false

# ── OpenTelemetry (optional) ───────────────────────────────────────────────────
# Set to activate opt-in tracing. Leave unset to disable entirely.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=mcp-infra-lens
